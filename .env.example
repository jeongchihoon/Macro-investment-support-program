# 필수 - 없으면 뉴스 기능 미작동
NEWS_API_KEY=your_newsapi_key_here

# 선택 - 없어도 기본 데이터 작동 (제한적)
FRED_API_KEY=your_fred_api_key_here

# 필수 - Gemini AI 기능 전체 (가이던스 분석, 번역, 경쟁사 선정, 심층 리서치)
# https://aistudio.google.com 에서 무료 발급
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here  # GEMINI_API_KEY와 둘 중 하나만 있어도 됨

# 선택 - 없으면 실적 발표 시뮬레이터 비활성화 (https://finnhub.io 에서 무료 발급)
FINNHUB_API_KEY=your_finnhub_api_key_here

# 선택 - 심층 리서치 검색 품질 향상
TAVILY_API_KEY=your_tavily_key_here
PARALLEL_API_KEY=your_parallel_key_here
